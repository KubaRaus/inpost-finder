@model InpostTask.Web.Models.PointSearchResultViewModel

@{
    ViewData["Title"] = "Search results";
    var request = Model.Request;
    var requestedFunctions = string.IsNullOrWhiteSpace(request.RequiredFunctionsCsv)
        ? Array.Empty<string>()
        : request.RequiredFunctionsCsv
            .Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToArray();
    var hasAnyFilter = !string.IsNullOrWhiteSpace(request.CountryCode)
                       || !string.IsNullOrWhiteSpace(request.City)
                       || !string.IsNullOrWhiteSpace(request.RequiredFunctionsCsv)
                       || request.Require247
                       || request.RequirePayment;
}

<h1 class="mb-3">Search Results</h1>

<p class="text-muted">
    Loaded <strong>@Model.TotalFetchedPoints</strong> points from API cache/source.
    Showing top <strong>@Model.Points.Count</strong> matches.
</p>

@if (hasAnyFilter)
{
    <div class="mb-3">
        <span class="text-muted me-2">Active filters:</span>
        @if (!string.IsNullOrWhiteSpace(request.CountryCode))
        {
            <span class="badge text-bg-light border me-1">Country: @request.CountryCode</span>
        }
        @if (!string.IsNullOrWhiteSpace(request.City))
        {
            <span class="badge text-bg-light border me-1">City: @request.City</span>
        }
        @if (!string.IsNullOrWhiteSpace(request.RequiredFunctionsCsv))
        {
            <span class="badge text-bg-light border me-1">Functions: @request.RequiredFunctionsCsv</span>
        }
        @if (request.Require247)
        {
            <span class="badge text-bg-light border me-1">24/7 only</span>
        }
        @if (request.RequirePayment)
        {
            <span class="badge text-bg-light border me-1">Payment required</span>
        }
    </div>
}

<p>
    <a asp-action="Index" asp-controller="Points" class="btn btn-outline-secondary">New search</a>
</p>

@if (Model.Points.Count == 0)
{
    <div class="alert alert-warning">No points matched your criteria.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Score</th>
                    <th>Name</th>
                    <th>City</th>
                    <th>Address</th>
                    <th>Country</th>
                    <th>Matched features</th>
                    <th>Coordinates</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var ranked in Model.Points)
            {
                <tr>
                    <td>
                        <strong>@ranked.Score</strong>
                        @if (ranked.ScoreBreakdown.Count > 0)
                        {
                            <div class="small text-muted">@string.Join("; ", ranked.ScoreBreakdown)</div>
                        }
                    </td>
                    <td>@ranked.Point.Name</td>
                    <td>@(ranked.Point.City ?? "-")</td>
                    <td>@(ranked.Point.AddressLine1 ?? "-")</td>
                    <td>@(ranked.Point.CountryCode ?? "-")</td>
                    <td>
                        @{
                            var matchedFunctions = requestedFunctions.Length == 0
                                ? Array.Empty<string>()
                                : ranked.Point.Functions
                                    .Where(function =>
                                        requestedFunctions.Any(required =>
                                            function.Contains(required, StringComparison.OrdinalIgnoreCase)))
                                    .Distinct(StringComparer.OrdinalIgnoreCase)
                                    .ToArray();
                        }
                        @if (requestedFunctions.Length == 0)
                        {
                            <span class="text-muted small">No function filter</span>
                        }
                        else if (matchedFunctions.Length == 0)
                        {
                            <span class="text-muted small">No direct function match</span>
                        }
                        else
                        {
                            <span>@string.Join(", ", matchedFunctions)</span>
                        }

                        <details class="mt-1">
                            <summary class="small">All features (@ranked.Point.Functions.Count)</summary>
                            <div class="small text-muted">@string.Join(", ", ranked.Point.Functions)</div>
                        </details>
                    </td>
                    <td>
                        @if (ranked.Point.Latitude is not null && ranked.Point.Longitude is not null)
                        {
                            @($"{ranked.Point.Latitude:0.00000}, {ranked.Point.Longitude:0.00000}")
                        }
                        else
                        {
                            @("-")
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
